<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.effect.Bloom?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane id="root" stylesheets="@../../static/css/style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.Controller">
   <children>
      <HBox id="topBar" alignment="CENTER" minHeight="70.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
         <children>
            <Label id="labelTitulo" alignment="CENTER" contentDisplay="CENTER" text="PlanGuide" textAlignment="CENTER">
               <font>
                  <Font size="32.0" />
               </font>
            </Label>
         </children>
      </HBox>
      <HBox alignment="CENTER" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="180.0">
         <children>
            <VBox id="painelCadastro" alignment="CENTER" maxWidth="1300.0" minHeight="400.0" minWidth="1300.0" spacing="20.0" HBox.hgrow="ALWAYS">
               <children>
                  <Label id="labelCadastroDisciplina" blendMode="DARKEN" minWidth="1300.0" text="Cadastro de disciplina:">
                     <font>
                        <Font name="Arial Bold" size="16.0" />
                     </font>
                     <VBox.margin>
                        <Insets />
                     </VBox.margin>
                  </Label>
                  <HBox alignment="CENTER" spacing="100.0" VBox.vgrow="ALWAYS">
                     <children>
                        <VBox minWidth="450.0" spacing="10.0">
                           <children>
                              <TextField id="tfNomeDisciplina" opacity="0.8" promptText="Nome" stylesheets="@../../static/css/style.css">
                                 <font>
                                    <Font size="20.0" />
                                 </font>
                              </TextField>
                              <ComboBox id="cbCurso" maxWidth="450.0" minWidth="450.0" promptText="Curso" stylesheets="@../../static/css/style.css">
                                 <effect>
                                    <Bloom threshold="0.63" />
                                 </effect>
                                 <opaqueInsets>
                                    <Insets />
                                 </opaqueInsets>
                              </ComboBox>
                              <HBox spacing="10.0">
                                 <children>
                                    <ComboBox id="cbSemestre" maxWidth="265.0" minWidth="265.0" promptText="Semestre" stylesheets="@../../static/css/style.css">
                                       <effect>
                                          <Bloom threshold="0.81" />
                                       </effect>
                                    </ComboBox>
                                    <ComboBox id="cbCargaHoraria" maxWidth="175.0" minWidth="175.0" promptText="Carga Horária">
                                       <effect>
                                          <Bloom threshold="0.63" />
                                       </effect>
                                    </ComboBox>
                                 </children>
                              </HBox>
                           </children>
                        </VBox>
                        <VBox spacing="10.0">
                           <children>
                              <HBox spacing="10.0">
                                 <children>
                                    <ComboBox id="cbDia" minWidth="160.0" promptText="Dia" stylesheets="@../../static/css/style.css">
                                       <effect>
                                          <Bloom threshold="0.63" />
                                       </effect>
                                    </ComboBox>
                                    <ComboBox id="cbInicio" minWidth="145.0" promptText="00h00" stylesheets="@../../static/css/style.css">
                                       <effect>
                                          <Bloom threshold="0.63" />
                                       </effect>
                                    </ComboBox>
                                    <ComboBox id="cbFim" minWidth="145.0" promptText="00h00">
                                       <effect>
                                          <Bloom threshold="0.63" />
                                       </effect>
                                    </ComboBox>
                                    <Button id="btnAdicionar" minHeight="46.0" minWidth="100.0" mnemonicParsing="false" stylesheets="@../../static/css/style.css" text="+ Adicionar" textAlignment="CENTER">
                                       <font>
                                          <Font size="14.0" />
                                       </font>
                                    </Button>
                                 </children>
                              </HBox>
                              <VBox fx:id="painelHorarios" minHeight="120.0" prefHeight="120.0">
                                 <Label id="labelHorarios" fx:id="labelHorarios" prefHeight="48.0" prefWidth="579.0" text="Horários da disciplina">
                                    <font>
                                       <Font size="24.0" />
                                    </font>
                                 </Label>
      
                                                         <TableView id="tableHorarios" fx:id="tabelaHorarios" VBox.vgrow="ALWAYS">
                                    <columns>
                                       <TableColumn id="colHorario" fx:id="colHorario" prefWidth="245.0" />
                                    </columns>
                                 </TableView>
                              </VBox>
                           </children>
                        </VBox>
                     </children>
                  </HBox>
                  <HBox alignment="CENTER_RIGHT" prefHeight="46.0" prefWidth="1416.0" VBox.vgrow="ALWAYS">
                     <children>
                        <Button id="btnSalvarDisciplina" alignment="CENTER" mnemonicParsing="false" stylesheets="@../../static/css/style.css" text="Salvar Disciplina" textAlignment="CENTER" />
                     </children>
                     <padding>
                        <Insets bottom="20.0" right="20.0" />
                     </padding>
                  </HBox>
               </children>
            </VBox>
         </children>
      </HBox>
      <HBox alignment="CENTER" layoutY="600.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="600.0">
         <children>
            <HBox alignment="CENTER_LEFT" maxWidth="1300.0" minWidth="1300.0">
               <children>
                  <Button maxHeight="250.0" maxWidth="250.0" minHeight="250.0" minWidth="250.0" mnemonicParsing="false" onAction="#clicarDisciplina" styleClass="cardDisciplina">
                     <graphic>
                        <VBox alignment="CENTER" prefHeight="285.0" prefWidth="303.0">
                           <children>
                              <VBox alignment="CENTER" prefHeight="195.0" prefWidth="293.0">
                                 <children>
                                    <ImageView fitHeight="157.0" fitWidth="90.0" pickOnBounds="true" preserveRatio="true">
                                       <image>
                                          <Image url="@../../static/imagens/folder.png" />
                                       </image>
                                    </ImageView>
                                 </children>
                              </VBox>
                              <VBox alignment="TOP_CENTER" prefHeight="178.0" prefWidth="333.0" styleClass="cardBgTitulo">
                                 <children>
                                    <Label prefHeight="103.0" prefWidth="312.0" styleClass="cardNomeDisciplina" text="Modelagem de Banco de dados" textAlignment="CENTER" wrapText="true">
                                       <font>
                                          <Font name="System Bold" size="21.0" />
                                       </font>
                                    </Label>
                                    <Label prefHeight="49.0" prefWidth="273.0" styleClass="cardSubtituloDisciplina" text="Banco de dados - 2º Sem" textAlignment="CENTER" wrapText="true">
                                       <font>
                                          <Font size="23.0" />
                                       </font>
                                    </Label>
                                 </children>
                              </VBox>
                           </children>
                        </VBox>
                     </graphic>
                  </Button>
               </children>
            </HBox>
         </children>
      </HBox>
   </children>
</AnchorPane>
